<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VTAvalonia.ViewModels"
        mc:Ignorable="d"
        x:Class="VTAvalonia.Views.AboutWindow"
        x:DataType="vm:AboutViewModel"
        Width="360" Height="200"
        WindowStartupLocation="CenterOwner"
        Title="About">
  <Design.DataContext>
    <vm:AboutViewModel />
  </Design.DataContext>

  <StackPanel Margin="16" Spacing="8">
    <TextBlock Text="{Binding ProductName}" FontSize="18" />
    <TextBlock Text="Version: {Binding Version}" />
    <Button Content="OK" HorizontalAlignment="Right" Click="OkButton_Click" />
  </StackPanel>
</Window>
