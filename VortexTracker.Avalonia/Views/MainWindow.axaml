<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VortexTracker.Avalonia.ViewModels"
        x:Class="VortexTracker.Avalonia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding Title}"
        Width="1400" Height="800"
        Background="#1E1E1E">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        
        <!-- Menu/Toolbar -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="?? Load" Click="OnLoadClick" Padding="12,6" Background="#007ACC" Foreground="White"/>
                <Button Content="?? Save" Padding="12,6" Background="#0E639C" Foreground="White"/>
                <Separator Width="1" Background="#3E3E42"/>
                <Button Content="?? Play" Click="OnPlayClick" Padding="12,6" Background="#16825D" Foreground="White"/>
                <Button Content="?? Stop" Click="OnStopClick" Padding="12,6" Background="#6D6D6D" Foreground="White"/>
                <Separator Width="1" Background="#3E3E42"/>
                <Button Content="??" Click="OnFirstPosClick" Padding="8,6" ToolTip.Tip="First Position"/>
                <Button Content="??" Click="OnPrevPosClick" Padding="8,6" ToolTip.Tip="Previous Position"/>
                <TextBlock Text="{Binding Tracker.CurrentPosition, StringFormat='Pos: {0:X2}'}" 
                           VerticalAlignment="Center" Foreground="White" Margin="8,0"/>
                <Button Content="??" Click="OnNextPosClick" Padding="8,6" ToolTip.Tip="Next Position"/>
                <Button Content="??" Click="OnLastPosClick" Padding="8,6" ToolTip.Tip="Last Position"/>
            </StackPanel>
        </Border>
        
        <!-- Module Info Bar -->
        <Border Grid.Row="1" Background="#252526" Padding="10,6" BorderBrush="#3E3E42" BorderThickness="0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="??" FontSize="16"/>
                    <TextBlock Text="{Binding Tracker.Title}" FontWeight="Bold" Foreground="#4EC9B0"/>
                    <TextBlock Text="by" Foreground="#858585"/>
                    <TextBlock Text="{Binding Tracker.Author}" Foreground="#DCDCDC"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="15" Margin="20,0,0,0">
                    <TextBlock Foreground="#858585">
                        <Run Text="Positions:"/>
                        <Run Text="{Binding Tracker.PositionCount}" Foreground="White"/>
                    </TextBlock>
                    <TextBlock Foreground="#858585">
                        <Run Text="Patterns:"/>
                        <Run Text="{Binding Tracker.PatternCount}" Foreground="White"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Tracker.CurrentPatternInfo}" Foreground="#CE9178"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="2" ColumnDefinitions="200,*,250">
            
            <!-- Left Sidebar: Positions -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="POSITIONS" Padding="10,8" 
                               Background="#2D2D30" Foreground="#858585" FontWeight="Bold" FontSize="11"/>
                    
                    <ListBox Grid.Row="1" ItemsSource="{Binding Tracker.Positions}" 
                             SelectedIndex="{Binding Tracker.CurrentPosition}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Background="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Index, StringFormat='{}{0:X2}'}" 
                                                   FontFamily="Consolas" Foreground="#858585" Width="30"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PatternNumber, StringFormat='{}{0:X2}'}" 
                                                   FontFamily="Consolas" Foreground="#4EC9B0" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="?" 
                                                   IsVisible="{Binding IsLoop}" Foreground="#CE9178"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- Center: Pattern Editor -->
            <Border Grid.Column="1" Background="#1E1E1E">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#2D2D30" Padding="10,8" BorderBrush="#3E3E42" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="PATTERN EDITOR" 
                                       Foreground="#858585" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding Tracker.CurrentPatternInfo}" 
                                       Foreground="#CE9178" FontSize="11"/>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tracker.PatternLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2D2D30" BorderThickness="0,0,0,1" Padding="4,2">
                                        <Grid ColumnDefinitions="50,90,50,200,200,200">
                                            <TextBlock Grid.Column="0" Text="{Binding LineNumberHex}" 
                                                       FontFamily="Consolas" FontSize="12" Foreground="#6A9955" Margin="8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding EnvelopeStr}" 
                                                       FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                                            <TextBlock Grid.Column="2" Text="{Binding NoiseStr}" 
                                                       FontFamily="Consolas" FontSize="12" Foreground="#D4D4D4"/>
                                            <TextBlock Grid.Column="3" Text="{Binding ChannelA}" 
                                                       FontFamily="Consolas" FontSize="12" Foreground="#4EC9B0" FontWeight="Medium"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ChannelB}" 
                                                       FontFamily="Consolas" FontSize="12" Foreground="#569CD6" FontWeight="Medium"/>
                                            <TextBlock Grid.Column="5" Text="{Binding ChannelC}" 
                                                       FontFamily="Consolas" FontSize="12" Foreground="#CE9178" FontWeight="Medium"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Right Sidebar: Samples & Ornaments -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto,*">
                    
                    <!-- Samples Header -->
                    <Grid Grid.Row="0" Background="#2D2D30" ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="SAMPLES" Padding="10,8" 
                                   Foreground="#858585" FontWeight="Bold" FontSize="11"/>
                        <Button Grid.Column="1" Content="?" Padding="6,4" Margin="2" Click="OnPrevSampleClick"/>
                        <Button Grid.Column="2" Content="?" Padding="6,4" Margin="2" Click="OnNextSampleClick"/>
                    </Grid>
                    
                    <!-- Samples List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tracker.SampleLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2D2D30" BorderThickness="0,0,0,1" Padding="6,2">
                                        <Grid ColumnDefinitions="35,25,25,45,35,35">
                                            <TextBlock Grid.Column="0" Text="{Binding LineNumberHex}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#6A9955"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ToneStr}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#CE9178"/>
                                            <TextBlock Grid.Column="2" Text="{Binding NoiseStr}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#CE9178"/>
                                            <TextBlock Grid.Column="3" Text="{Binding ToneValue}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#4EC9B0"/>
                                            <TextBlock Grid.Column="4" Text="{Binding NoiseValue}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#569CD6"/>
                                            <TextBlock Grid.Column="5" Text="{Binding AmplitudeValue}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#DCDCDC"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Ornaments Header -->
                    <Grid Grid.Row="2" Background="#2D2D30" ColumnDefinitions="*,Auto,Auto" BorderBrush="#3E3E42" BorderThickness="0,1,0,0">
                        <TextBlock Grid.Column="0" Text="ORNAMENTS" Padding="10,8" 
                                   Foreground="#858585" FontWeight="Bold" FontSize="11"/>
                        <Button Grid.Column="1" Content="?" Padding="6,4" Margin="2" Click="OnPrevOrnamentClick"/>
                        <Button Grid.Column="2" Content="?" Padding="6,4" Margin="2" Click="OnNextOrnamentClick"/>
                    </Grid>
                    
                    <!-- Ornaments List -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tracker.OrnamentLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2D2D30" BorderThickness="0,0,0,1" Padding="6,2">
                                        <Grid ColumnDefinitions="35,*">
                                            <TextBlock Grid.Column="0" Text="{Binding LineNumberHex}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#6A9955"/>
                                            <TextBlock Grid.Column="1" Text="{Binding NoteStr}" 
                                                       FontFamily="Consolas" FontSize="10" Foreground="#4EC9B0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#007ACC" Padding="10,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Tracker.StatusText}" 
                           Foreground="White" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="Avalonia Cross-Platform | F1 Help" 
                           Foreground="#E0E0E0" FontSize="10" Opacity="0.8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
